{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/otto-device.zip", "dest": "/public/otto-device.zip" },
    
    { "src": "/dashboard", "dest": "/public/dashboard.html" },
    
    { "src": "/dashboard.html", "dest": "/public/dashboard.html" },
    
    { "src": "/index.html", "dest": "/public/index.html" },
    
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}



